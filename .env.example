# ── Jarvis AI 서버 로컬 환경 예시 ─────────────────────────────
# 모든 값은 pydantic-settings Settings 필드와 1:1 대응한다 (config 주입 원칙).
# 실사용 시 이 파일을 .env 로 복사해 값을 채운다.

# ── Anthropic 2-tier LLM ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
HAIKU_MODEL_ID=claude-haiku-4-5
SONNET_MODEL_ID=claude-sonnet-5

# ── Google 임베딩 API (MVP, api-spec §4.8 v0.15.14 — 셀프호스트 torch 폐기) ──
GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL_ID=gemini-embedding-001
EMBEDDING_DIM=1536
# 주기 증분 pull 배치 스케줄러 간격(초)
CATALOG_BATCH_INTERVAL_S=300

# ── PostgreSQL ×2 ──
# docker-compose 기준: catalog=5433, profile=5434 (호스트 포트)
# catalog: MVP 에서 order_seed 호스트, profile: 프로필 스토어.
CATALOG_DB_URL=postgresql://jarvis:jarvis@localhost:5433/catalog
PROFILE_DB_URL=postgresql://jarvis:jarvis@localhost:5434/profile

# ── Spring 연동 (역방향 호출: 검색·장바구니, api-spec §4) ──
SPRING_BASE_URL=http://localhost:8080

# ── CORS (FE 직접 호출, api-spec §2.7 / C-11) ──
# JSON 배열 문자열로 주입한다.
CORS_ORIGINS=["http://localhost:3000"]

# ── 인증 (api-spec §2.2, RS256 + JWKS 확정 2026-07-15) ──
# dev : 서명 검증 없이 디코드 (헤더 없으면 게스트로 취급) — 로컬 개발 전용
# jwks: Spring GET /.well-known/jwks.json 공개키로 RS256 검증 (kid→키, exp/iss/aud)
AUTH_MODE=dev
JWKS_URL=http://localhost:8080/.well-known/jwks.json
JWT_ISSUER=shopping-spring-auth
JWT_AUDIENCE=shopping-fastapi-ai
# 스트림 티켓 scope 검증값 (§2.3 검증 항목). 미설정 시 scope 검증 생략 —
# C-1 로 실값 확정 후 운영(jwks) 전환 시 반드시 주입 (예: chat:stream).
# JWT_SCOPE=chat:stream

# ── 이벤트 채널 서비스 토큰 (DEPRECATED, 고도화 재도입 대비) ──
# /events/* 는 고도화(post-MVP)로 이동해 현재 미사용.
SERVICE_TOKEN=

# ── 검색/추천 튜너블 (SPEC-RECOMMEND-001) ──
SEARCH_DEFAULT_LIMIT=30
TOP_K=30
EXPOSE_MIN=5
EXPOSE_MAX=8
LLM_CALL_LIMIT=2
RELAXATION_MAX_ROUNDS=3

# ── 프로필 (SPEC-PROFILE-001, 내부 전용) ──
PROFILE_SUMMARY_MAX_CHARS=1000
